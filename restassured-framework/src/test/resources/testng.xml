<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    =========================================================
    testng.xml
    =========================================================
    TestNG suite configuration file.

    Features configured here:
      - Parallel test execution (parallel="methods" = run test methods in parallel)
      - Thread count for parallelism
      - Global listeners (RetryListener, ExtentReport)
      - Test groups (smoke, regression)
      - Suite parameters (overridable from CI/CD)

    Run the full suite:
      mvn test

    Run only smoke tests:
      mvn test -Dgroups=smoke

    Run with UAT environment:
      mvn test -Denv=uat
    =========================================================
-->

<suite name="API Automation Suite"
       verbose="1"
       parallel="methods"
       thread-count="3"
       data-provider-thread-count="2">

    <!-- ============================================
         Global Listeners
         ============================================ -->
    <listeners>
        <!-- Applies RetryAnalyzer to ALL test methods globally -->
        <listener class-name="com.api.framework.utils.RetryListener"/>
    </listeners>

    <!-- ============================================
         Suite-Level Parameters
         Accessible via @Parameter in tests
         ============================================ -->
    <parameter name="env"      value="qa"/>
    <parameter name="browser"  value="chrome"/>

    <!-- ============================================
         SMOKE TEST GROUP
         Run: mvn test -Dgroups=smoke
         ============================================ -->
    <test name="Smoke Tests" enabled="true">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.api.framework.tests.AuthTests"/>
            <class name="com.api.framework.tests.UserTests"/>
        </classes>
    </test>

    <!-- ============================================
         REGRESSION TEST GROUP
         Run: mvn test -Dgroups=regression
         ============================================ -->
    <test name="Regression Tests" enabled="true">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.api.framework.tests.AuthTests"/>
            <class name="com.api.framework.tests.UserTests"/>
        </classes>
    </test>

    <!-- ============================================
         FULL SUITE (All tests)
         ============================================ -->
    <test name="Full Suite" enabled="false">
        <classes>
            <class name="com.api.framework.tests.AuthTests"/>
            <class name="com.api.framework.tests.UserTests"/>
        </classes>
    </test>

</suite>
