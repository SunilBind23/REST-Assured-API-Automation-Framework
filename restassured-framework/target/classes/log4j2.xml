<?xml version="1.0" encoding="UTF-8"?>
<!--
    Log4j2 Configuration File
    Controls logging behavior across the framework.
    Logs are output to both console and a rotating file.
-->
<Configuration status="WARN">

    <Appenders>

        <!-- Console Appender: Logs to standard output with color -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>

        <!-- File Appender: Writes logs to a rolling file -->
        <RollingFile name="FileAppender"
                     fileName="logs/framework.log"
                     filePattern="logs/framework-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{36} - %msg%n"/>
            <Policies>
                <!-- Roll over daily -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <!-- Roll over when file exceeds 10MB -->
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <!-- Keep max 30 log files -->
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

    </Appenders>

    <Loggers>
        <!-- Framework-specific logger: DEBUG level for detailed output -->
        <Logger name="com.api.framework" level="DEBUG" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- REST Assured HTTP logging -->
        <Logger name="org.apache.http" level="WARN" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
        </Logger>

        <!-- Root logger: INFO level as default -->
        <Root level="INFO">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Root>
    </Loggers>

</Configuration>
