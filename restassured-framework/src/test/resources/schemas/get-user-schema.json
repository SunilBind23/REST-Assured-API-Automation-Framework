{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Get User Response Schema",
  "description": "Schema for validating the GET /api/users/{id} response",
  "type": "object",
  "required": ["data", "support"],
  "properties": {
    "data": {
      "type": "object",
      "required": ["id", "email", "first_name", "last_name", "avatar"],
      "properties": {
        "id": { "type": "integer" },
        "email": { "type": "string", "format": "email" },
        "first_name": { "type": "string" },
        "last_name": { "type": "string" },
        "avatar": { "type": "string", "format": "uri" }
      }
    },
    "support": {
      "type": "object",
      "required": ["url", "text"],
      "properties": {
        "url": { "type": "string" },
        "text": { "type": "string" }
      }
    }
  }
}
